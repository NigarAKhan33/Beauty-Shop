<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource">
      <DataSourceReference>DataSource</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>6b3993e1-244a-49a8-8415-8ed823057e97</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource</DataSourceName>
        <CommandText>SELECT 
    d.FullDate AS Release_Date,
    ty.type AS Title_Type,
    COUNT(*) AS Total_Titles,
    SUM(CASE WHEN t.duration LIKE '%min' THEN 1 ELSE 0 END) AS Total_Movies,
    SUM(CASE WHEN t.duration LIKE '%Season' THEN 1 ELSE 0 END) AS Total_TV_Shows
FROM 
    Title_Fact AS t
JOIN 
    Date_Dim AS d ON t.DateKey = d.DateKey
JOIN 
    Type_Dim AS ty ON t.TypeID = ty.TypeID
GROUP BY 
    d.FullDate,
    ty.type
ORDER BY 
    Release_Date ASC;</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Release_Date">
          <DataField>Release_Date</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Title_Type">
          <DataField>Title_Type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Total_Titles">
          <DataField>Total_Titles</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Total_Movies">
          <DataField>Total_Movies</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Total_TV_Shows">
          <DataField>Total_TV_Shows</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
