<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource">
      <DataSourceReference>DataSource</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>f37469e1-1d1b-41b0-8551-919e62f49e7e</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource</DataSourceName>
        <CommandText>SELECT 
    c.country AS Country,
    d.FullDate AS Release_Date,
    ty.type AS Title_Type,
    COUNT(*) AS Title_Count,
    AVG(DATEDIFF(year, CONVERT(date, t.release_year), CONVERT(date, d.FullDate))) AS Avg_Years_Since_Release
FROM 
    Title_Fact AS t
JOIN 
    Country_Dim AS c ON t.CountryID = c.CountryID
JOIN 
    Date_Dim AS d ON t.DateKey = d.DateKey
JOIN 
    Type_Dim AS ty ON t.TypeID = ty.TypeID
GROUP BY 
    c.country,
    d.FullDate,
    ty.type
HAVING 
    COUNT(*) &gt; 5
ORDER BY 
    Avg_Years_Since_Release DESC, 
    Title_Count DESC;</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Country">
          <DataField>Country</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Release_Date">
          <DataField>Release_Date</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Title_Type">
          <DataField>Title_Type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Title_Count">
          <DataField>Title_Count</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Avg_Years_Since_Release">
          <DataField>Avg_Years_Since_Release</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
